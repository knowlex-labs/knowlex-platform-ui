{
  "expo": {
    "name": "Knowlex",
    "slug": "knowlex",
    "scheme": "knowlex",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#7A2E2E"
    },
    "android": {
      "package": "com.knowlex.app"
    },
    "ios": {
      "bundleIdentifier": "com.knowlex.app",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiBaseUrl": "http://localhost:8080",
      "googleClientId": ""
    }
  }
}
